# Copy to .env and adjust. docker-compose.yml reads these; safe defaults are
# used if a variable is missing.

# REQUIRED in production: a long random string, e.g. from
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string

# "True" only for local development
DJANGO_DEBUG=False

# comma-separated hostnames
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# comma-separated origins (scheme + host), needed for POST forms behind a domain
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000

# Set to True only when the site is served over HTTPS (enables SSL redirect,
# secure cookies, and HSTS)
DJANGO_SECURE_SSL=False

# PostgreSQL connection; docker-compose sets this itself for the bundled db.
# Leave unset to fall back to local SQLite (simple local usage without Docker).
# DATABASE_URL=postgres://tonevault:tonevault@db:5432/tonevault
